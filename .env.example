# Sanity
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01
# Read token (draft preview). Leave empty for public datasets.
SANITY_API_READ_TOKEN=
# Write token (quote-lead persistence + AI assistant). Required to save leads.
SANITY_API_WRITE_TOKEN=
# Secret shared with the Sanity revalidation webhook.
SANITY_REVALIDATE_SECRET=

# AI Quote Assistant (optional — wizard works in guided mode without it)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929

# Email (optional — leads are still saved to Sanity without it)
RESEND_API_KEY=
CONTACT_FROM_EMAIL=leads@eastrims.com
SALES_EMAIL=ice@eastrims.com

# Site URL (SEO: sitemap, robots, JSON-LD)
NEXT_PUBLIC_SITE_URL=https://eastrims.com

# Google Images MCP (@srigi/mcp-google-images-search — .mcp.json maps these onto API_KEY / SEARCH_ENGINE_ID)
# 1) Enable "Custom Search API" in the GCP project that owns GOOGLE_API_KEY.
# 2) Create a Programmable Search Engine (sites: *, turn ON "Image search") -> its ID is GOOGLE_CX:
#    https://programmablesearchengine.google.com/
GOOGLE_API_KEY=
GOOGLE_CX=
